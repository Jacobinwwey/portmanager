{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portmanager.dev/schemas/port-diagnostic-result.schema.json",
  "title": "PortDiagnosticResult",
  "type": "object",
  "required": ["schemaVersion", "hostId", "port", "tcpReachable", "capturedAt"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "hostId": { "type": "string" },
    "ruleId": { "type": "string" },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "tcpReachable": { "type": "boolean" },
    "httpStatus": { "type": "integer" },
    "pageTitle": { "type": "string" },
    "finalUrl": { "type": "string" },
    "tls": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "subject": { "type": "string" },
        "issuer": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "validitySummary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "capturedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
